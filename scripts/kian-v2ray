#!/usr/bin/env bash
# ============================================================================
#  kian-v2ray — management tool  (installed at /usr/local/bin/kian-v2ray)
#  Repo: https://github.com/KIAN-IRANI/kian_v2ray
#
#  Commands:
#     kian-v2ray status              service and user status
#     kian-v2ray configs [name]      show config links + terminal QR
#     kian-v2ray sub [name]          build the subscription file (random per-user token)
#     kian-v2ray users               list users + usage/expiry
#     kian-v2ray add <name> [GB] [days] [all|domain|nodomain]   add a user (default 100GB / 30d)
#     kian-v2ray filter <name> <all|domain|nodomain>   set which config types this user gets
#     kian-v2ray remove <name>       remove a user
#     kian-v2ray reset <name> [GB]   reset usage (and set quota if given)
#     kian-v2ray renew <name> [days] extend validity from now
#     kian-v2ray update              full update: Xray + scripts + panel + protocols + sub sync
#     kian-v2ray resync              rebuild every user's subscription + Gist sync (after a protocol change)
#     kian-v2ray fixport             fix API port conflict (crash loop on a server with another panel)
#     kian-v2ray rebind              rebuild Xray allowed to bind ports below 1024 (443/80)
#     kian-v2ray warp                retry WARP (WireGuard/MASQUE) and restore from fallback
#     kian-v2ray untune              revert network tuning (BBR/buffers)
#     kian-v2ray uninstall           full removal
#  "name" can be the part before @ in the user's email (e.g. user-1).
# ============================================================================
set -uo pipefail

CONTAINER="kian-xray"
WARP_PORT=40000
GIB=1073741824
RAW_BASE="https://raw.githubusercontent.com/KIAN-IRANI/kian_v2ray/main"
# config.json باید برای کاربر غیر-root کانتینر Xray خواندنی باشد (وگرنه permission denied → کرش‌لوپ)
ensure_cfg_perm(){ [ -f "$CONFIG" ] && chmod 644 "$CONFIG" 2>/dev/null || true; }
# همگام‌سازی فایل‌های sub محلی با گیست‌های HTTPS گیت‌هاب (از طریق Worker، در صورت تنظیم)
gist_sync(){
  [ -f "$ETC_DIR/gist_proxy" ] || return 0
  [ -f /usr/local/bin/kian-gist-sync.py ] || return 0
  local proxy; proxy="$(cat "$ETC_DIR/gist_proxy" 2>/dev/null)"
  [ -n "$proxy" ] || return 0
  python3 /usr/local/bin/kian-gist-sync.py "$proxy" "$ETC_DIR/install_id" "$ETC_DIR/sub" "$ETC_DIR/gist_map.json" >/dev/null 2>&1 || true
}
ETC_DIR="/etc/kian-v2ray"
XRAY_DIR="/etc/kian-v2ray"          # config.json ایزوله (به /etc/xray دست نمی‌زند)
LOG_DIR="/var/log/kian-xray"
USERS_FILE="$ETC_DIR/users.json"
LINKS_FILE="$ETC_DIR/links.txt"
INFO_FILE="$ETC_DIR/info.txt"
IMAGE_FILE="$ETC_DIR/image.txt"
CONFIG="$XRAY_DIR/config.json"
API_FILE="$ETC_DIR/api.txt"
# پورت API ممکن است در نصب auto-fix شده باشد (مشکل ۰.۱) → از api.txt یا خود config بخوان
if [ -f "$API_FILE" ]; then API="$(cat "$API_FILE" 2>/dev/null)"; fi
[ -z "${API:-}" ] && API="127.0.0.1:$(jq -r '(.inbounds[]|select(.tag=="api")|.port)//10085' "$CONFIG" 2>/dev/null || echo 10085)"

C_G='\033[1;32m'; C_Y='\033[1;33m'; C_R='\033[1;31m'; C_B='\033[1;36m'; C_D='\033[2m'; C_N='\033[0m'
say(){ printf "${C_G}✔${C_N} %s\n" "$*"; }
inf(){ printf "${C_B}→${C_N} %s\n" "$*"; }
warn(){ printf "${C_Y}⚠${C_N} %s\n" "$*"; }
err(){ printf "${C_R}✘${C_N} %s\n" "$*" >&2; }
need_root(){ [ "$(id -u)" -eq 0 ] || { err "This command needs root (sudo)."; exit 1; }; }
need_jq(){ command -v jq >/dev/null 2>&1 || { err "jq is not installed."; exit 1; }; }
need_files(){ [ -f "$CONFIG" ] && [ -f "$USERS_FILE" ] || { err "Install not found. Install from the web page first."; exit 1; }; }

# --- استخراج اطلاعات سرور از config.json + links.txt ----------------------
meta_ip(){ awk -F': ' '/Server IP/{print $2; exit}' "$INFO_FILE" 2>/dev/null | tr -d ' '; }
meta_sni(){ jq -r '[.inbounds[]|select((.tag//"")|startswith("reality-"))|.streamSettings.realitySettings.serverNames[0]][0] // empty' "$CONFIG" 2>/dev/null; }
meta_sid(){ jq -r '[.inbounds[]|select((.tag//"")|startswith("reality-"))|.streamSettings.realitySettings.shortIds[0]][0] // empty' "$CONFIG" 2>/dev/null; }
meta_pbk(){ grep -oE 'pbk=[A-Za-z0-9_-]+' "$LINKS_FILE" 2>/dev/null | head -1 | cut -d= -f2; }
meta_port(){ jq -r --arg t "$1" '[.inbounds[]|select(.tag==$t)|.port][0] // empty' "$CONFIG" 2>/dev/null; }
meta_ss(){ jq -r '[.inbounds[]|select(.tag=="shadowsocks")|{p:.port,pw:(.settings.password // .settings.clients[0].password),m:(.settings.method // .settings.clients[0].method)}][0] // empty | if .==null then "" else "\(.p) \(.m) \(.pw)" end' "$CONFIG" 2>/dev/null; }

urlenc_label(){ printf '%s' "$1" | sed 's/ /%20/g'; }   # برچسب ساده‌ی ASCII

build_vless(){ # uuid port sni label
  local uuid="$1" port="$2" sni="$3" label="$4"
  printf 'vless://%s@%s:%s?encryption=none&flow=xtls-rprx-vision&security=reality&sni=%s&fp=chrome&pbk=%s&sid=%s&type=tcp#%s\n' \
    "$uuid" "$(meta_ip)" "$port" "$sni" "$(meta_pbk)" "$(meta_sid)" "$(urlenc_label "$label")"
}

# دامنه TLS اگر فاز ۳ نصب شده باشد
meta_tls_domain(){ [ -f "$ETC_DIR/tls_domain.txt" ] && cat "$ETC_DIR/tls_domain.txt" 2>/dev/null || true; }

# لینک‌ساز TLS برای vless WS/gRPC/HTTPUpgrade
build_vless_tls(){ # uuid net path label
  local uuid="$1" net="$2" path="$3" label="$4" dom; dom="$(meta_tls_domain)"
  [ -z "$dom" ] && return
  local q="encryption=none&security=tls&sni=${dom}&fp=chrome&host=${dom}&type=${net}"
  if [ "$net" = "ws" ] || [ "$net" = "httpupgrade" ]; then q="${q}&path=$(printf '%s' "$path" | sed 's:/:%2F:g')"
  elif [ "$net" = "grpc" ]; then q="${q}&serviceName=${path#/}&mode=gun"; fi
  printf 'vless://%s@%s:443?%s#%s\n' "$uuid" "$dom" "$q" "$(urlenc_label "$label")"
}
# لینک‌ساز TLS برای trojan
build_trojan_tls(){ # uuid net path label
  local uuid="$1" net="$2" path="$3" label="$4" dom; dom="$(meta_tls_domain)"
  [ -z "$dom" ] && return
  local q="security=tls&sni=${dom}&fp=chrome&host=${dom}&type=${net}"
  if [ "$net" = "ws" ] || [ "$net" = "httpupgrade" ]; then q="${q}&path=$(printf '%s' "$path" | sed 's:/:%2F:g')"
  elif [ "$net" = "grpc" ]; then q="${q}&serviceName=${path#/}&mode=gun"; fi
  printf 'trojan://%s@%s:443?%s#%s\n' "$uuid" "$dom" "$q" "$(urlenc_label "$label")"
}
# لینک‌ساز TLS برای vmess (JSON base64 طبق فرمت v2rayN)
build_vmess_tls(){ # uuid net path label
  local uuid="$1" net="$2" path="$3" label="$4" dom; dom="$(meta_tls_domain)"
  [ -z "$dom" ] && return
  local netv="$net" pathv="$path"
  [ "$net" = "grpc" ] && pathv="${path#/}"
  local json
  json=$(jq -nc --arg ps "$label" --arg add "$dom" --arg id "$uuid" \
    --arg net "$netv" --arg host "$dom" --arg path "$pathv" --arg sni "$dom" \
    '{v:"2",ps:$ps,add:$add,port:"443",id:$id,aid:"0",scy:"auto",net:$net,type:"none",host:$host,path:$path,tls:"tls",sni:$sni,alpn:"",fp:"chrome"}')
  printf 'vmess://%s\n' "$(printf '%s' "$json" | base64 -w0)"
}
show_qr(){ command -v qrencode >/dev/null 2>&1 && printf '%s' "$1" | qrencode -t ANSIUTF8 -m 1 2>/dev/null || true; }

# --- بازسازی clientها در reality inbounds از روی users.json + restart -----
rebuild_and_restart(){
  local active_full active_simple active_trojan cfgtmp
  # Reality و TLS-vless/vmess: flow + uuid + email
  active_full="$(jq -c '[.users[]|select(.active==true)|{id:.id,email:.email,flow:"xtls-rprx-vision"}]' "$USERS_FILE")"
  active_simple="$(jq -c '[.users[]|select(.active==true)|{id:.id,email:.email}]' "$USERS_FILE")"
  # Trojan: password=uuid (که قبلاً در صفحه همین قرارداد را داشت) + email
  active_trojan="$(jq -c '[.users[]|select(.active==true)|{password:.id,email:.email}]' "$USERS_FILE")"
  cfgtmp="$(mktemp)"
  # یک jq تمیز که هر سه نوع inbound را همزمان آپدیت می‌کند
  jq --argjson cf "$active_full" --argjson cs "$active_simple" --argjson ct "$active_trojan" '
    .inbounds |= map(
      if   ((.tag//"")|startswith("reality-")) then .settings.clients=$cf
      elif (.protocol=="vless"  and ((.tag//"")|startswith("tls-"))) then .settings.clients=$cs
      elif (.protocol=="vmess"  and ((.tag//"")|startswith("tls-"))) then .settings.clients=$cs
      elif (.protocol=="trojan" and ((.tag//"")|startswith("tls-"))) then .settings.clients=$ct
      else . end
    )' "$CONFIG" > "$cfgtmp" 2>/dev/null
  if jq -e . "$cfgtmp" >/dev/null 2>&1; then
    mv "$cfgtmp" "$CONFIG"
    ensure_cfg_perm
    docker restart "$CONTAINER" >/dev/null 2>&1 || true
    say "Config rebuilt and Xray restarted"
  else
    rm -f "$cfgtmp"; err "Config rebuild failed"; return 1
  fi
}

resolve_email(){ # نام یا ایمیل → ایمیل دقیق
  local q="$1"
  jq -r --arg q "$q" '[.users[]|.email|select(. == $q or (split("@")[0] == $q))][0] // empty' "$USERS_FILE"
}

# ===========================================================================
cmd_status(){
  printf "\n${C_B}━━━ kian-v2ray — Status ━━━${C_N}\n\n"
  local PROBLEMS=""
  if docker ps --format '{{.Names}}' 2>/dev/null | grep -qx "$CONTAINER"; then
    say "Xray is running  ($(cat "$IMAGE_FILE" 2>/dev/null || echo image))"
    docker ps --filter "name=$CONTAINER" --format '   Uptime: {{.Status}}'
  else
    # خودتشخیصی (۰.۳): کرش‌لوپ یا توقف؟
    local st; st="$(docker inspect -f '{{.State.Status}}' "$CONTAINER" 2>/dev/null || echo missing)"
    if [ "$st" = "restarting" ]; then
      err "Xray is crash-looping (Restarting)"
      # علت رایج: تداخل پورت bind در لاگ
      local logtail; logtail="$(docker logs "$CONTAINER" --tail 30 2>&1 || true)"
      if printf '%s' "$logtail" | grep -qiE 'permission denied'; then
        err "Cause: config.json permission (container can't read it). Fix: kian-v2ray fixperm"
        PROBLEMS="perm"
      elif printf '%s' "$logtail" | grep -qiE 'address already in use|bind:.*in use|listen.*fail'; then
        local badport; badport="$(printf '%s' "$logtail" | grep -oiE ':[0-9]+: bind|:[0-9]+ .*in use' | grep -oE '[0-9]+' | head -1)"
        err "Cause: port conflict${badport:+ ($badport)} — likely another panel (3x-ui/Marzban) took that port"
        PROBLEMS="port"
      else
        PROBLEMS="crash"
      fi
    elif [ "$st" = "missing" ]; then
      err "Xray container does not exist"
      PROBLEMS="missing"
    else
      err "Xray is not running (status: $st)"
      PROBLEMS="stopped"
    fi
  fi
  if command -v warp-cli >/dev/null 2>&1; then
    if curl -fsS --max-time 8 --socks5 "127.0.0.1:$WARP_PORT" https://1.1.1.1/cdn-cgi/trace 2>/dev/null | grep -q 'warp=on'; then
      say "WARP: connected (socks5 :$WARP_PORT$( [ -f "$ETC_DIR/warp_proto.txt" ] && printf ' — %s' "$(cat "$ETC_DIR/warp_proto.txt")"))"
      if [ "$(cat "$ETC_DIR/warp_fallback.txt" 2>/dev/null)" = on ]; then
        warn "but routing is still on fallback (direct) — to restore: kian-v2ray warp"
        PROBLEMS="${PROBLEMS:+$PROBLEMS,}warpfb"
      fi
    elif [ "$(cat "$ETC_DIR/warp_fallback.txt" 2>/dev/null)" = on ]; then
      warn "WARP down — fallback active: warp traffic goes direct for now (users stay online)"
      PROBLEMS="${PROBLEMS:+$PROBLEMS,}warp"
    else warn "WARP: down — watchdog will retry, or run: kian-v2ray warp"; PROBLEMS="${PROBLEMS:+$PROBLEMS,}warp"; fi
  else inf "WARP not installed (direct mode)"; fi
  # تداخل پورت API را مستقل هم چک کن
  local apiport; apiport="${API##*:}"
  if [ -n "$apiport" ] && ss -tln 2>/dev/null | awk '{print $4}' | grep -qE "[:.]${apiport}\$"; then
    if ! docker ps --format '{{.Names}}' | grep -qx "$CONTAINER"; then
      warn "API port ($apiport) is taken by another service"
      case "$PROBLEMS" in *port*) :;; *) PROBLEMS="${PROBLEMS:+$PROBLEMS,}apiport";; esac
    fi
  fi
  if [ -f "$USERS_FILE" ]; then
    local total act
    total="$(jq '.users|length' "$USERS_FILE" 2>/dev/null)"
    act="$(jq '[.users[]|select(.active==true)]|length' "$USERS_FILE" 2>/dev/null)"
    inf "Users: $act active of $total"
  fi
  # --- چک Service ports: واقعاً listening هستند؟ (مهم برای تشخیص مشکل پورت/فایروال) ---
  local svc_ports lport_problem=""
  svc_ports="$(jq -r '.inbounds[]|select(((.tag//"")|startswith("reality-")) or (.tag=="shadowsocks"))|.port' "$CONFIG" 2>/dev/null)"
  if [ -n "$svc_ports" ]; then
    printf "\n${C_B}Service ports:${C_N}\n"
    for p in $svc_ports; do
      if ss -tln 2>/dev/null | awk '{print $4}' | grep -qE "[:.]${p}\$"; then
        printf "   ✅ %s — listening\n" "$p"
      else
        printf "   ❌ %s — not listening (Xray down or port not bound)\n" "$p"
        lport_problem=1
      fi
    done
    # هشدار فایروال: اگر ufw فعال است، آیا این پورت‌ها allow شده‌اند؟
    if command -v ufw >/dev/null 2>&1 && ufw status 2>/dev/null | grep -qi '^Status: active'; then
      local fw_missing=""
      for p in $svc_ports; do
        ufw status 2>/dev/null | grep -qE "(^|[^0-9])${p}(/|[[:space:]])" || fw_missing="$fw_missing $p"
      done
      if [ -n "$fw_missing" ]; then
        warn "Firewall is active but these ports are not open in ufw:$fw_missing"
        PROBLEMS="${PROBLEMS:+$PROBLEMS,}fw"
      else
        say "Firewall: all service ports are open"
      fi
    fi
    [ -n "$lport_problem" ] && PROBLEMS="${PROBLEMS:+$PROBLEMS,}listen"
  fi
  # --- دستور رفع (۰.۳): یک خط، بدون نیاز به دانش کاربر ---
  if [ -n "$PROBLEMS" ]; then
    printf "\n${C_Y}━━━ Auto-fix ━━━${C_N}\n"
    case "$PROBLEMS" in
      *port*|*apiport*|*missing*)
        printf "   Port conflict detected. This moves the API port to a free one and brings Xray up:\n"
        printf "${C_G}   kian-v2ray fixport${C_N}\n" ;;
    esac
    case "$PROBLEMS" in
      *warpfb*) printf "   WARP is healthy but routing is stuck on fallback. Restore:  ${C_G}kian-v2ray warp${C_N}\n" ;;
    esac
    case "$PROBLEMS" in
      *warp*) printf "   WARP is down. Retry (WireGuard/MASQUE + fallback):  ${C_G}kian-v2ray warp${C_N}\n" ;;
    esac
    case "$PROBLEMS" in
      *perm*) printf "   config permission issue. Quick fix:  ${C_G}kian-v2ray fixperm${C_N}\n" ;;
    esac
    case "$PROBLEMS" in
      *crash*) printf "   crash log:  ${C_G}docker logs $CONTAINER --tail 40${C_N}\n" ;;
    esac
    case "$PROBLEMS" in
      *fw*) printf "   ports not open in the firewall. Auto-open:  ${C_G}kian-v2ray openports${C_N}\n" ;;
    esac
    case "$PROBLEMS" in
      *listen*) printf "   service port not listening. Restart Xray:  ${C_G}docker restart $CONTAINER${C_N}  or  ${C_G}kian-v2ray fixport${C_N}\n" ;;
    esac
    echo ""
  else
    printf "\n${C_D}For links: kian-v2ray configs   |   List users: kian-v2ray users${C_N}\n\n"
  fi
}

# --- مدیریت دستی WARP: تلاش مجدد (WireGuard/MASQUE) و برگرداندن از fallback ---
_warp_up(){ curl -fsS --max-time 8 --socks5 "127.0.0.1:$WARP_PORT" https://1.1.1.1/cdn-cgi/trace 2>/dev/null | grep -q 'warp=on'; }
_warp_restore_routing(){
  # outbound warp را از freedom (fallback) به socks برمی‌گرداند — هماهنگ با
  # مدلِ جدید که فقط دامنه‌های منتخب از warp می‌روند.
  local FB="$ETC_DIR/warp_fallback.txt" tmp
  [ "$(cat "$FB" 2>/dev/null)" = on ] || return 0
  command -v jq >/dev/null 2>&1 || return 0
  jq -e '.outbounds[]?|select(.tag=="warp")' "$CONFIG" >/dev/null 2>&1 || { echo off > "$FB"; return 0; }
  tmp="$(mktemp)"
  jq --argjson port "$WARP_PORT" '(.outbounds[]|select(.tag=="warp"))|={tag:"warp",protocol:"socks",settings:{servers:[{address:"127.0.0.1",port:$port}]}}' "$CONFIG" > "$tmp" \
    && jq -e . "$tmp" >/dev/null 2>&1 && mv "$tmp" "$CONFIG" || rm -f "$tmp"
  echo off > "$FB"; ensure_cfg_perm; docker restart "$CONTAINER" >/dev/null 2>&1 || true
  say "WARP restored: warp traffic goes through WARP again"
}
# --- بازگرداندن بهینه‌سازی شبکه (rollback مرحلهٔ ۰.۴) ----------------------
cmd_untune(){
  need_root
  local f="/etc/sysctl.d/99-kian-v2ray.conf"
  if [ -f "$f" ]; then rm -f "$f"; say "tune file removed ($f)"; else inf "tune file did not exist"; fi
  rm -f /etc/modules-load.d/bbr.conf 2>/dev/null || true
  sysctl --system >/dev/null 2>&1 || true
  inf "To fully revert the kernel settings, reboot the server (or see the values in $ETC_DIR/sysctl.backup)."
  say "Network tuning reverted"
}

cmd_warp(){
  need_root
  command -v warp-cli >/dev/null 2>&1 || { err "WARP is not installed."; exit 1; }

  # اول سرویس رو بالا بیار (ممکنه down باشه)
  systemctl is-active --quiet warp-svc 2>/dev/null || systemctl start warp-svc 2>/dev/null || true
  sleep 2

  inf "Trying to connect WARP (WireGuard)..."
  warp-cli --accept-tos disconnect >/dev/null 2>&1 || true
  sleep 1
  warp-cli --accept-tos connect >/dev/null 2>&1 || true
  sleep 8   # WireGuard handshake ممکن است تا ۸ ثانیه طول بکشد

  if ! _warp_up; then
    # تلاش با MASQUE (HTTP/3 روی UDP 443 — اغلب از فیلترینگ رد می‌شود)
    inf "WireGuard did not connect — trying MASQUE (UDP 443)..."
    warp-cli --accept-tos tunnel protocol set MASQUE >/dev/null 2>&1 \
      || warp-cli --accept-tos set-tunnel-protocol masque >/dev/null 2>&1 || true
    warp-cli --accept-tos disconnect >/dev/null 2>&1; sleep 1
    warp-cli --accept-tos connect >/dev/null 2>&1 || true
    sleep 10
  fi

  if ! _warp_up; then
    # برگشت به WireGuard یک بار دیگر با reset کامل ثبت
    inf "MASQUE did not connect either — resetting and retrying WireGuard..."
    warp-cli --accept-tos tunnel protocol set WireGuard >/dev/null 2>&1 || true
    warp-cli --accept-tos registration delete >/dev/null 2>&1 || true
    sleep 1
    warp-cli --accept-tos registration new >/dev/null 2>&1 || true
    sleep 2
    warp-cli --accept-tos connect >/dev/null 2>&1 || true
    sleep 8
  fi

  if _warp_up; then
    say "WARP is connected ✅"
    # پروتکل فعلی رو ذخیره کن (برای نمایش در status)
    warp-cli --accept-tos tunnel protocol get 2>/dev/null \
      | grep -oiE 'wireguard|masque' | head -1 > "$ETC_DIR/warp_proto.txt" || true
    _warp_restore_routing
  else
    err "WARP still not connected — fallback (direct) stays active so users keep internet."
    warn "Possible fixes:"
    warn "  1) UDP may be blocked on this server or ISP — check UDP port 443"
    warn "  2) Try again:  kian-v2ray warp"
    warn "  3) For the exact error:  warp-cli --accept-tos status"
  fi
}

# --- رفع خودکار تداخل پورت API (۰.۱/۰.۳) ----------------------------------
cmd_fixport(){
  need_root; need_jq; need_files
  local cur free
  cur="$(jq -r '(.inbounds[]|select(.tag=="api")|.port)//10085' "$CONFIG")"
  if ! ss -tln 2>/dev/null | awk '{print $4}' | grep -qE "[:.]${cur}\$" || docker ps --format '{{.Names}}'|grep -qx "$CONTAINER"; then
    inf "Current API port ($cur) is fine — trying restart"
  fi
  free="$cur"
  local svc_ports; svc_ports="$(jq -r '[.inbounds[]|select(((.tag//"")|startswith("reality-")) or ((.tag//"")=="shadowsocks"))|.port]|join(" ")' "$CONFIG")"
  for _t in $(seq 1 300); do
    free=$(( (RANDOM % 30000) + 20000 ))
    ss -tln 2>/dev/null | awk '{print $4}' | grep -qE "[:.]${free}\$" && continue
    printf '%s\n' $svc_ports | grep -qx "$free" && continue
    break
  done
  local tmpc; tmpc="$(mktemp)"
  jq --argjson new "$free" '(.inbounds[]|select(.tag=="api")|.port)|=$new' "$CONFIG" > "$tmpc" && mv "$tmpc" "$CONFIG"
  jq -e . "$CONFIG" >/dev/null || { err "config is broken — restore needed"; exit 1; }
  echo "127.0.0.1:${free}" > "$API_FILE"
  ensure_cfg_perm
  docker restart "$CONTAINER" >/dev/null 2>&1 || docker start "$CONTAINER" >/dev/null 2>&1 || true
  sleep 3
  if docker ps --format '{{.Names}}'|grep -qx "$CONTAINER"; then say "API port changed to $free and Xray came up ✅"
  else err "still not up — log: docker logs $CONTAINER --tail 40"; fi
}

cmd_users(){
  need_jq; need_files
  printf "\n${C_B}%-22s %-9s %-12s %-12s %s${C_N}\n" "Email" "Active" "Used" "Quota" "Expiry"
  printf '%.0s─' {1..72}; printf '\n'
  jq -r '.users[] | [
      .email, (if .active then "yes" else "no" end),
      ((.used_bytes/1073741824*100|floor)/100|tostring)+"G",
      (if .quota_bytes>0 then ((.quota_bytes/1073741824)|tostring)+"G" else "∞" end),
      (.expires_at // "permanent")
    ] | @tsv' "$USERS_FILE" | while IFS=$'\t' read -r e a u q x; do
      printf "%-22s %-9s %-12s %-12s %s\n" "$e" "$a" "$u" "$q" "$x"
    done
  echo ""
}

cmd_configs(){
  need_jq; need_files
  local filter="${1:-}" ss inbounds_tsv
  ss="$(meta_ss)"
  [ -n "$(meta_pbk)" ] || { err "public key not found in links.txt."; exit 1; }

  # همهٔ inboundهای reality:  tag \t port \t sni
  inbounds_tsv="$(jq -r '.inbounds[]|select((.tag//"")|startswith("reality-"))|[.tag,(.port|tostring),(.streamSettings.realitySettings.serverNames[0]//"")]|@tsv' "$CONFIG")"

  jq -r '.users[]|select(.active==true)|.id+"\t"+.email' "$USERS_FILE" | while IFS=$'\t' read -r uuid email; do
    local local_name="${email%@*}"
    [ -n "$filter" ] && [ "$filter" != "$local_name" ] && [ "$filter" != "$email" ] && continue
    printf "\n${C_B}👤 %s${C_N}\n" "$local_name"
    printf '%s\n' "$inbounds_tsv" | while IFS=$'\t' read -r tag port sni; do
      [ -z "$tag" ] && continue
      local l; l="$(build_vless "$uuid" "$port" "$sni" "${local_name}-reality-${port}")"
      printf "${C_G}• Reality · %s · port %s:${C_N}\n%s\n" "$sni" "$port" "$l"; show_qr "$l"
    done
    # کانفیگ‌های TLS (فاز ۳) — اگر دامنه نصب باشد
    if [ -n "$(meta_tls_domain)" ]; then
      local tls_tsv
      tls_tsv="$(jq -r '.inbounds[]|select((.tag//"")|startswith("tls-"))|[.tag,.protocol,(.streamSettings.network//"ws"),(.streamSettings.wsSettings.path // .streamSettings.httpupgradeSettings.path // ("/"+(.streamSettings.grpcSettings.serviceName//"")) // "/")]|@tsv' "$CONFIG" 2>/dev/null)"
      printf '%s\n' "$tls_tsv" | while IFS=$'\t' read -r t_tag t_proto t_net t_path; do
        [ -z "$t_tag" ] && continue
        local lbl="${local_name}-${t_tag#tls-}-443" link=""
        case "$t_proto" in
          vless)  link="$(build_vless_tls "$uuid" "$t_net" "$t_path" "$lbl")";;
          vmess)  link="$(build_vmess_tls "$uuid" "$t_net" "$t_path" "$lbl")";;
          trojan) link="$(build_trojan_tls "$uuid" "$t_net" "$t_path" "$lbl")";;
        esac
        [ -n "$link" ] && { printf "${C_G}• TLS · %s · %s:${C_N}\n%s\n" "$t_proto" "$t_net" "$link"; show_qr "$link"; }
      done
    fi
  done
  if [ -n "$ss" ] && { [ -z "$filter" ] || [ "$filter" = "ss" ]; }; then
    read -r sp sm spw <<<"$ss"
    local l; l="ss://$(printf '%s' "$sm:$spw" | base64 -w0)@$(meta_ip):$sp#shadowsocks-${sp}"
    printf "\n${C_B}🧩 Shadowsocks (shared):${C_N}\n%s\n" "$l"; show_qr "$l"
  fi
  echo ""
}

# --- لینک Subscription (فاز ۲): توکن تصادفی هر کاربر + فایل base64 ---------
# فایل خروجی همان لینک‌های کانفیگِ خودِ کاربر است (فرمت استاندارد v2rayNG).
# سرویس دائم اجرا نمی‌شود؛ فایل ساخته می‌شود تا کاربر جایی (Gist/Pages) آپلود کند.
cmd_sub(){
  need_root; need_jq; need_files
  local filter="${1:-}" tokfile="$ETC_DIR/sub_tokens.json" subdir="$ETC_DIR/sub"
  mkdir -p "$subdir"; [ -f "$tokfile" ] || echo '{}' > "$tokfile"
  local pbk; pbk="$(meta_pbk)"; [ -n "$pbk" ] || { err "public key not found."; exit 1; }
  local ss; ss="$(meta_ss)"
  local inbounds_tsv; inbounds_tsv="$(jq -r '.inbounds[]|select((.tag//"")|startswith("reality-"))|[.tag,(.port|tostring),(.streamSettings.realitySettings.serverNames[0]//"")]|@tsv' "$CONFIG")"
  jq -r '.users[]|select(.active==true)|.id+"\t"+.email+"\t"+(.sub_filter//"all")' "$USERS_FILE" | while IFS=$'\t' read -r uuid email ufilter; do
    local local_name="${email%@*}"
    [ -n "$filter" ] && [ "$filter" != "$local_name" ] && [ "$filter" != "$email" ] && continue
    # per-user config selection: "all" (default) | "domain" (TLS protocols only) |
    # "nodomain" (Reality/Shadowsocks/Hysteria2/TUIC — IP-based only).
    [ "$ufilter" = "domain" ] || [ "$ufilter" = "nodomain" ] || ufilter="all"
    # توکن تصادفی یک‌بارساخت (در صورت نبود)
    local tok; tok="$(jq -r --arg e "$email" '.[$e]//empty' "$tokfile")"
    if [ -z "$tok" ]; then
      tok="$(head -c18 /dev/urandom | base64 | tr -dc 'a-zA-Z0-9' | head -c24)"
      local tt; tt="$(mktemp)"; jq --arg e "$email" --arg t "$tok" '.[$e]=$t' "$tokfile" > "$tt" && mv "$tt" "$tokfile"; chmod 600 "$tokfile"
    fi
    # جمع‌آوری همهٔ لینک‌های این کاربر
    local all=""
    # Reality (no-domain / IP-based) — included unless the user is domain-only
    if [ "$ufilter" != "domain" ]; then
    while IFS=$'\t' read -r tag port sni; do
      [ -z "$tag" ] && continue
      all="${all}$(build_vless "$uuid" "$port" "$sni" "${local_name}-reality-${port}")"$'\n'
    done <<EOF
$inbounds_tsv
EOF
    fi
    # لینک‌های TLS (فاز ۳) — اگر دامنه نصب شده باشد و کاربر no-domain-only نباشد
    if [ -n "$(meta_tls_domain)" ] && [ "$ufilter" != "nodomain" ]; then
      local tls_tsv
      tls_tsv="$(jq -r '.inbounds[]|select((.tag//"")|startswith("tls-"))|[.tag,.protocol,(.streamSettings.network//"ws"),(.streamSettings.wsSettings.path // .streamSettings.httpupgradeSettings.path // ("/"+(.streamSettings.grpcSettings.serviceName//"")) // "/")]|@tsv' "$CONFIG" 2>/dev/null)"
      while IFS=$'\t' read -r t_tag t_proto t_net t_path; do
        [ -z "$t_tag" ] && continue
        local tls_label="${local_name}-${t_tag#tls-}-443"
        local tls_link=""
        case "$t_proto" in
          vless)  tls_link="$(build_vless_tls "$uuid" "$t_net" "$t_path" "$tls_label")";;
          vmess)  tls_link="$(build_vmess_tls "$uuid" "$t_net" "$t_path" "$tls_label")";;
          trojan) tls_link="$(build_trojan_tls "$uuid" "$t_net" "$t_path" "$tls_label")";;
        esac
        [ -n "$tls_link" ] && all="${all}${tls_link}"$'\n'
      done <<EOF
$tls_tsv
EOF
    fi
    if [ -n "$ss" ] && [ "$ufilter" != "domain" ]; then
      read -r sp sm spw <<<"$ss"
      all="${all}ss://$(printf '%s' "$sm:$spw" | base64 -w0)@$(meta_ip):$sp#${local_name}-shadowsocks-${sp}"$'\n'
    fi
    # لینک‌های Hysteria2/TUIC این کاربر (IP-based) — کاربرِ domain-only آن‌ها را نمی‌گیرد
    if [ -f "$ETC_DIR/extra_links.txt" ] && [ "$ufilter" != "domain" ]; then
      local ex; ex="$(grep -F "#${local_name}-" "$ETC_DIR/extra_links.txt" 2>/dev/null || true)"
      [ -n "$ex" ] && all="${all}${ex}"$'\n'
    fi
    # فایل subscription = base64 از مجموعهٔ لینک‌ها (فرمت v2rayNG)
    local outfile="$subdir/${tok}.txt"
    printf '%s' "$all" | base64 -w0 > "$outfile"
    # همگام‌سازی Gist (فایل عوض شده، گیست هم آپدیت شود)
    gist_sync
    local subports; subports="$(cat "$ETC_DIR/sub_port.txt" 2>/dev/null || echo 80)"
    local ip; ip="$(meta_ip)"
    # لینک Gist (HTTPS — تضمینی) را از gist_map پیدا کن
    local gist_url=""
    [ -f "$ETC_DIR/gist_map.json" ] && gist_url="$(jq -r --arg t "$tok" '.[$t].url // ""' "$ETC_DIR/gist_map.json" 2>/dev/null)"
    # لینک HTTPS روی دامنهٔ خودِ کاربر (از طریق Caddy روی :443 → سرور محلی sub).
    # فقط وقتی نشان داده می‌شود که: دامنه ست شده، Caddy بالا باشد، و مسیرِ /sub/* واقعاً
    # در Caddyfile تزریق شده باشد — وگرنه لینک به‌جای Subscription صفحهٔ «It works!» می‌دهد.
    local tls_dom="" dom_url=""
    [ -f "$ETC_DIR/tls_domain.txt" ] && tls_dom="$(cat "$ETC_DIR/tls_domain.txt" 2>/dev/null)"
    if [ -n "$tls_dom" ] && systemctl is-active caddy >/dev/null 2>&1 \
       && grep -q 'path /sub/\*' /etc/caddy/Caddyfile 2>/dev/null; then
      dom_url="https://${tls_dom}/sub/${tok}"
    fi
    printf "\n${C_B}👤 %s${C_N}\n" "$local_name"
    # هر دو لینکِ HTTPS را نشان بده تا کاربر خودش انتخاب کند (هر دو در v2rayNG کار می‌کنند).
    if [ -n "$dom_url" ]; then
      say "⭐ Subscription on your own domain (HTTPS):"
      printf "  ${C_G}%s${C_N}\n" "$dom_url"
      inf "Hosted on your own domain & certificate — no dependency on our Gist."
    fi
    if [ -n "$gist_url" ]; then
      say "⭐ Subscription on Gist (HTTPS):"
      printf "  ${C_G}%s${C_N}\n" "$gist_url"
      inf "Works on all providers and firewalls."
    fi
    # لینک‌های پشتیبان فقط در صورتی نشان داده شوند که هیچ HTTPS در دسترس نبود
    # (v2rayNG فقط https://Subscription می‌پذیرد، پس http همه را به اشتباه نمی‌اندازد)
    if [ -z "$gist_url" ] && [ -z "$dom_url" ] && systemctl is-active kian-sub >/dev/null 2>&1; then
      printf "\n"
      warn "Gist and HTTPS domain unavailable — backup links work only for curl/browser, not v2rayNG:"
      for sp in $(echo "$subports" | tr ',' ' '); do
        [ -n "$sp" ] && [ "$sp" != "8765" ] && printf "    http://${ip}:${sp}/sub/${tok}\n"
      done
      inf "To import in v2rayNG, upload the raw file to a public Gist, or run 'kian-v2ray configs' and copy the links one by one."
    fi
    if [ -z "$gist_url" ] && [ -z "$dom_url" ] && ! systemctl is-active kian-sub >/dev/null 2>&1; then
      warn "No Gist, no HTTPS domain, and no sub service is active. Raw file: $outfile"
    fi
  done
}

cmd_add(){
  need_root; need_jq; need_files
  local name="${1:-}" gb="${2:-100}" days="${3:-30}" flt="${4:-all}"
  [ "$flt" = "domain" ] || [ "$flt" = "nodomain" ] || flt="all"   # per-user config selection
  [ -n "$name" ] || { err "Name required:  kian-v2ray add <name> [quota_GB] [days] [all|domain|nodomain]"; exit 1; }
  name="$(printf '%s' "$name" | tr -cd 'a-zA-Z0-9_-')"
  local email="${name}@kian"
  if jq -e --arg e "$email" '.users[]|select(.email==$e)' "$USERS_FILE" >/dev/null 2>&1; then
    err "A user with email $email already exists."; exit 1
  fi
  local uuid quota exp tmp
  uuid="$(cat /proc/sys/kernel/random/uuid)"
  quota=$(( gb * GIB )); [ "$gb" -le 0 ] && quota=0
  if [ "$days" -gt 0 ]; then exp="\"$(date -u -d "+${days} days" +%FT%TZ)\""; else exp="null"; fi
  tmp="$(mktemp)"
  jq --arg id "$uuid" --arg e "$email" --argjson q "$quota" --argjson x "$exp" --arg f "$flt" \
    '.users += [{id:$id,email:$e,quota_bytes:$q,used_bytes:0,expires_at:$x,active:true,note:"",sub_filter:$f}]' \
    "$USERS_FILE" > "$tmp" && mv "$tmp" "$USERS_FILE" && chmod 600 "$USERS_FILE"
  rebuild_and_restart
  # اگر کامپنیون Hysteria2/TUIC فعال است، کاربر جدید را به آن هم اضافه کن و
  # لینک‌های per-user او را به links.txt + extra_links.txt اضافه کن تا در
  # Subscription کاربر بیاید (وگرنه کاربر جدید این پروتکل‌ها را نمی‌گرفت).
  if [ -x /usr/local/bin/kian-protocols.sh ] && systemctl is-active --quiet kian-singbox 2>/dev/null; then
    if bash /usr/local/bin/kian-protocols.sh adduser "$name" >/dev/null 2>&1; then
      local new_extra; new_extra="$(bash /usr/local/bin/kian-protocols.sh links 2>/dev/null \
        | grep -F "#${name}-" || true)"
      if [ -n "$new_extra" ]; then
        printf '%s\n' "$new_extra" >> "$ETC_DIR/links.txt"
        printf '%s\n' "$new_extra" >> "$ETC_DIR/extra_links.txt"
      fi
    fi
  fi
  say "User added: $email  (quota: $([ "$gb" -le 0 ] && echo ∞ || echo ${gb}G) / period: $([ "$days" -le 0 ] && echo permanent || echo ${days}d))"
  # لینک Subscription کاربر را بساز (Reality + TLS + SS + Hy2/TUIC) و در Gist همگام کن
  cmd_sub "$name"
  cmd_configs "$name"
}

cmd_remove(){
  need_root; need_jq; need_files
  local q="${1:-}"; [ -n "$q" ] || { err "Name required:  kian-v2ray remove <name>"; exit 1; }
  local email; email="$(resolve_email "$q")"
  [ -n "$email" ] || { err "No user with name/email "$q" found."; exit 1; }
  local tmp; tmp="$(mktemp)"
  jq --arg e "$email" '.users |= map(select(.email != $e))' "$USERS_FILE" > "$tmp" && mv "$tmp" "$USERS_FILE" && chmod 600 "$USERS_FILE"
  rebuild_and_restart
  # کاربر را از کامپنیون Hysteria2/TUIC و از extra_links.txt هم حذف کن
  local rm_name="${email%@*}"
  if [ -x /usr/local/bin/kian-protocols.sh ] && systemctl is-active --quiet kian-singbox 2>/dev/null; then
    bash /usr/local/bin/kian-protocols.sh deluser "$rm_name" >/dev/null 2>&1 || true
  fi
  if [ -f "$ETC_DIR/extra_links.txt" ]; then
    grep -vF "#${rm_name}-" "$ETC_DIR/extra_links.txt" > "$tmp" 2>/dev/null && mv "$tmp" "$ETC_DIR/extra_links.txt" || rm -f "$tmp"
  fi
  # توکن Subscription کاربر را پاک کن و فایل sub او را حذف کن
  if [ -f "$ETC_DIR/sub_tokens.json" ]; then
    local rmtok; rmtok="$(jq -r --arg e "$email" '.[$e]//empty' "$ETC_DIR/sub_tokens.json" 2>/dev/null)"
    [ -n "$rmtok" ] && rm -f "$ETC_DIR/sub/${rmtok}.txt"
    tmp="$(mktemp)"; jq --arg e "$email" 'del(.[$e])' "$ETC_DIR/sub_tokens.json" > "$tmp" 2>/dev/null && mv "$tmp" "$ETC_DIR/sub_tokens.json" || rm -f "$tmp"
  fi
  gist_sync
  say "User removed: $email"
}

cmd_reset(){
  need_root; need_jq; need_files
  local q="${1:-}" gb="${2:-}"; [ -n "$q" ] || { err "Name required."; exit 1; }
  local email; email="$(resolve_email "$q")"; [ -n "$email" ] || { err "User not found."; exit 1; }
  local tmp; tmp="$(mktemp)"
  if [ -n "$gb" ]; then
    local quota=$(( gb * GIB )); [ "$gb" -le 0 ] && quota=0
    jq --arg e "$email" --argjson q "$quota" '.users |= map(if .email==$e then (.used_bytes=0|.active=true|.quota_bytes=$q) else . end)' "$USERS_FILE" > "$tmp"
  else
    jq --arg e "$email" '.users |= map(if .email==$e then (.used_bytes=0|.active=true) else . end)' "$USERS_FILE" > "$tmp"
  fi
  mv "$tmp" "$USERS_FILE" && chmod 600 "$USERS_FILE"
  rebuild_and_restart
  say "Usage reset: $email${gb:+  (new quota: ${gb}G)}"
}

cmd_renew(){
  need_root; need_jq; need_files
  local q="${1:-}" days="${2:-30}"; [ -n "$q" ] || { err "Name required."; exit 1; }
  local email; email="$(resolve_email "$q")"; [ -n "$email" ] || { err "User not found."; exit 1; }
  local exp tmp
  if [ "$days" -gt 0 ]; then exp="\"$(date -u -d "+${days} days" +%FT%TZ)\""; else exp="null"; fi
  tmp="$(mktemp)"
  jq --arg e "$email" --argjson x "$exp" '.users |= map(if .email==$e then (.expires_at=$x|.active=true) else . end)' "$USERS_FILE" > "$tmp"
  mv "$tmp" "$USERS_FILE" && chmod 600 "$USERS_FILE"
  rebuild_and_restart
  say "Renewed: $email  (until $([ "$days" -le 0 ] && echo permanent || echo "${days} more days"))"
}

# نصب‌های قدیمی را به مدلِ «لینکِ HTTPS روی دامنهٔ خودِ کاربر» ارتقا می‌دهد:
#  ۱) پورت پلِ ثابت (8765) را به sub_port.txt اضافه و kian-sub را ری‌استارت می‌کند
#     تا سرور محلیِ sub روی loopback در دسترسِ Caddy باشد.
#  ۲) اگر دامنه ست شده و Caddyfile مالِ ماست (تک‌بلوک)، هندلرِ /sub/* را به آن
#     تزریق و Caddy را reload می‌کند. کاملاً idempotent — اگر از قبل باشد کاری نمی‌کند.
ensure_domain_sub(){
  # (۱) پورت پل: 8765 را به لیستِ پورت‌های sub اضافه کن. نکته: ری‌استارتِ ساده
  #     کافی نیست چون ExecStart در یونیتِ systemd پورت‌های قدیمی را دارد و 8765
  #     bind نمی‌شود — پس اول ExecStart را به‌روز و daemon-reload می‌کنیم.
  local pf="$ETC_DIR/sub_port.txt" ports unit=/etc/systemd/system/kian-sub.service
  ports="$(cat "$pf" 2>/dev/null || echo 80)"
  case ",$ports," in
    *",8765,"*) : ;;
    *) ports="${ports},8765"; printf '%s' "$ports" > "$pf"
       if [ -f "$unit" ]; then
         sed -i -E "s#(ExecStart=.*kian-sub-server\.py )[^ ]+#\1${ports}#" "$unit"
         systemctl daemon-reload >/dev/null 2>&1 || true
       fi
       systemctl restart kian-sub >/dev/null 2>&1 || true ;;
  esac
  # (۲) هندلرِ Caddy
  local cf=/etc/caddy/Caddyfile dom=""
  [ -f "$ETC_DIR/tls_domain.txt" ] && dom="$(cat "$ETC_DIR/tls_domain.txt" 2>/dev/null)"
  [ -n "$dom" ] && [ -f "$cf" ] || return 0
  grep -q 'path /sub/\*' "$cf" 2>/dev/null && return 0
  # فقط وقتی دست بزن که Caddyfile دقیقاً یک بلوکِ دامنه دارد و آن بلوک مالِ ماست
  [ "$(grep -c '^[a-z0-9.-]\+ {' "$cf" 2>/dev/null)" = "1" ] || return 0
  grep -q "^${dom} {" "$cf" 2>/dev/null || return 0
  local tmp; tmp="$(mktemp)"
  # هندلر را درست قبل از اولین «handle {» بدونِ matcher (صفحهٔ طعمه) درج کن
  awk '
    !done && /^\thandle \{$/ {
      print "\t@kiansub {"; print "\t\tpath /sub/*"; print "\t}";
      print "\thandle @kiansub {"; print "\t\treverse_proxy 127.0.0.1:8765"; print "\t}";
      done=1
    }
    { print }
  ' "$cf" > "$tmp" 2>/dev/null || { rm -f "$tmp"; return 0; }
  if grep -q 'path /sub/\*' "$tmp" 2>/dev/null && caddy validate --config "$tmp" >/dev/null 2>&1; then
    cp "$cf" "$ETC_DIR/backups/Caddyfile_$(date -u +%Y%m%d-%H%M%S)" 2>/dev/null || true
    mv "$tmp" "$cf"
    systemctl reload caddy >/dev/null 2>&1 || systemctl restart caddy >/dev/null 2>&1 || true
    say "HTTPS link on domain $dom enabled (https://${dom}/sub/<token>)"
  else
    rm -f "$tmp"
  fi
}

# فعال‌سازیِ خودکارِ swap برای VPSهای کم‌رم (نصب‌های قدیمی هم با update می‌گیرند).
# امن و idempotent؛ روی OpenVZ/LXC که swap مجاز نیست با خطای ملایم رد می‌شود.
ensure_swap(){
  local cur_kb; cur_kb="$(awk '/SwapTotal/{print $2}' /proc/meminfo 2>/dev/null || echo 0)"
  [ "${cur_kb:-0}" -gt 0 ] && return 0
  local ram_mb; ram_mb="$(awk '/MemTotal/{print int($2/1024)}' /proc/meminfo 2>/dev/null || echo 0)"
  [ "${ram_mb:-0}" -gt 0 ] && [ "$ram_mb" -le 2048 ] || return 0
  local size_mb=2048 free_mb sf=/swapfile
  free_mb="$(df -Pm / 2>/dev/null | awk 'NR==2{print $4}')"
  [ "${free_mb:-0}" -ge $((size_mb + 1024)) ] || { warn "not enough disk for swap — skipped"; return 0; }
  inf "creating swap file (${size_mb} MB) for low-RAM server..."
  rm -f "$sf" 2>/dev/null || true
  fallocate -l "${size_mb}M" "$sf" 2>/dev/null \
    || dd if=/dev/zero of="$sf" bs=1M count="$size_mb" status=none 2>/dev/null \
    || { warn "creating swap failed — skipped"; rm -f "$sf"; return 0; }
  chmod 600 "$sf"
  mkswap "$sf" >/dev/null 2>&1 || { warn "mkswap failed (OpenVZ/LXC?) — skipped"; rm -f "$sf"; return 0; }
  swapon "$sf" 2>/dev/null || { warn "swapon failed — skipped"; rm -f "$sf"; return 0; }
  grep -qF "$sf" /etc/fstab 2>/dev/null || echo "$sf none swap sw 0 0" >> /etc/fstab
  printf 'vm.swappiness=10\nvm.vfs_cache_pressure=50\n' > /etc/sysctl.d/99-kian-swap.conf
  sysctl -p /etc/sysctl.d/99-kian-swap.conf >/dev/null 2>&1 || true
  say "swap enabled (${size_mb} MB) — prevents service crashes on low-RAM VPS"
}

cmd_update(){
  need_root
  # نسخهٔ پایدار را از VERSION ریپو بخوان (نه latest کور)
  inf "checking stable version..."
  local remote sv xv
  remote="$(curl -fsSL "$RAW_BASE/VERSION" 2>/dev/null || true)"
  sv="$(printf '%s' "$remote" | grep '^SCRIPT_VERSION=' | cut -d= -f2 | tr -d '\r ')"
  xv="$(printf '%s' "$remote" | grep '^XRAY_VERSION=' | cut -d= -f2 | tr -d '\r ')"
  [ -z "$xv" ] && xv="latest"
  local cur_sv; cur_sv="$(cat "$ETC_DIR/script_version.txt" 2>/dev/null || echo "?")"
  inf "Script version — current: $cur_sv | new: ${sv:-?}"
  inf "Xray version — target: $xv"

  # بکاپ همه‌چیز قبل از آپدیت (برای rollback)
  local bdir="$ETC_DIR/backups" bts; bts="$(date -u +%Y%m%d-%H%M%S)"
  mkdir -p "$bdir"
  cp "$CONFIG" "$bdir/config_${bts}.json" 2>/dev/null || true
  cp "$USERS_FILE" "$bdir/users_${bts}.json" 2>/dev/null || true
  cp /usr/local/bin/kian-v2ray "$bdir/kian-v2ray_${bts}" 2>/dev/null || true
  local prev_img; prev_img="$(cat "$IMAGE_FILE" 2>/dev/null || echo '')"
  echo "ROLLBACK_IMG=$prev_img" > "$bdir/rollback_${bts}.env"

  # ۱) آپدیت اسکریپت‌ها (manager + watchdog + sub-server + protocols + panel)
  inf "fetching new scripts..."
  local ok_scripts=1
  curl -fsSL "$RAW_BASE/scripts/kian-v2ray"   -o /usr/local/bin/kian-v2ray.new   && chmod +x /usr/local/bin/kian-v2ray.new   || ok_scripts=0
  curl -fsSL "$RAW_BASE/scripts/watchdog.sh"  -o /usr/local/bin/kian-v2ray-watchdog.sh.new && chmod +x /usr/local/bin/kian-v2ray-watchdog.sh.new || ok_scripts=0
  curl -fsSL "$RAW_BASE/scripts/sub-server.py" -o /usr/local/bin/kian-sub-server.py.new && chmod +x /usr/local/bin/kian-sub-server.py.new || ok_scripts=0
  # protocols + panel helper اسکریپت‌ها (برای قابلیت‌های جدید مثل AnyTLS و آپدیت پنل)
  curl -fsSL "$RAW_BASE/scripts/kian-protocols.sh" -o /usr/local/bin/kian-protocols.sh.tmp 2>/dev/null \
    && bash -n /usr/local/bin/kian-protocols.sh.tmp 2>/dev/null \
    && mv /usr/local/bin/kian-protocols.sh.tmp /usr/local/bin/kian-protocols.sh && chmod +x /usr/local/bin/kian-protocols.sh \
    || rm -f /usr/local/bin/kian-protocols.sh.tmp
  curl -fsSL "$RAW_BASE/scripts/kian-panel.sh" -o /usr/local/bin/kian-panel.sh.tmp 2>/dev/null \
    && bash -n /usr/local/bin/kian-panel.sh.tmp 2>/dev/null \
    && mv /usr/local/bin/kian-panel.sh.tmp /usr/local/bin/kian-panel.sh && chmod +x /usr/local/bin/kian-panel.sh \
    || rm -f /usr/local/bin/kian-panel.sh.tmp
  # اعتبارسنجی نحوی قبل از جایگزینی
  if [ "$ok_scripts" = 1 ] && bash -n /usr/local/bin/kian-v2ray.new 2>/dev/null && bash -n /usr/local/bin/kian-v2ray-watchdog.sh.new 2>/dev/null && python3 -c "import ast,sys; ast.parse(open('/usr/local/bin/kian-sub-server.py.new').read())" 2>/dev/null; then
    mv /usr/local/bin/kian-v2ray.new /usr/local/bin/kian-v2ray
    mv /usr/local/bin/kian-v2ray-watchdog.sh.new /usr/local/bin/kian-v2ray-watchdog.sh
    mv /usr/local/bin/kian-sub-server.py.new /usr/local/bin/kian-sub-server.py
    systemctl restart kian-sub >/dev/null 2>&1 || true
    say "scripts updated"
  else
    rm -f /usr/local/bin/*.new 2>/dev/null
    warn "fetch/validate of scripts failed — current scripts left untouched"
  fi

  # ۲) آپدیت Xray به نسخهٔ pin‌شده (با rollback اگر بالا نیامد)
  local img="ghcr.io/xtls/xray-core:$xv"
  ensure_cfg_perm
  if docker pull "$img" >/dev/null 2>&1; then
    docker rm -f "$CONTAINER" >/dev/null 2>&1 || true
    docker run -d --name "$CONTAINER" --restart unless-stopped --network host --memory="512m" --user 0:0 --cap-add=NET_BIND_SERVICE \
      -v "$CONFIG:/etc/xray/config.json:ro" -v "$LOG_DIR:/var/log/xray" \
      "$img" run -c /etc/xray/config.json >/dev/null 2>&1 || true
    sleep 3
    if docker ps --format '{{.Names}}' | grep -qx "$CONTAINER"; then
      echo "$img" > "$IMAGE_FILE"; say "Xray updated → $img"
    elif [ -n "$prev_img" ]; then
      warn "new version did not come up — rolling back to $prev_img"
      docker rm -f "$CONTAINER" >/dev/null 2>&1 || true
      docker run -d --name "$CONTAINER" --restart unless-stopped --network host --memory="512m" --user 0:0 --cap-add=NET_BIND_SERVICE \
        -v "$CONFIG:/etc/xray/config.json:ro" -v "$LOG_DIR:/var/log/xray" \
        "$prev_img" run -c /etc/xray/config.json >/dev/null 2>&1 || true
      sleep 2
      docker ps --format '{{.Names}}' | grep -qx "$CONTAINER" && say "rollback ok — previous version restored" || err "rollback failed too — log: docker logs $CONTAINER"
    fi
  else warn "pull of $img failed — Xray left untouched"; fi

  # ۳) اگر کامپنیون پروتکل‌ها (Hysteria2/TUIC/AnyTLS) فعال بود، دوباره enable کن
  #    تا پروتکل‌های جدید (مثل AnyTLS) خودکار اضافه شوند — بدون نصبِ دوباره.
  if [ -x /usr/local/bin/kian-protocols.sh ] && systemctl is-active --quiet kian-singbox 2>/dev/null; then
    inf "updating companion protocols (sing-box: Hysteria2/TUIC/AnyTLS)..."
    bash /usr/local/bin/kian-protocols.sh enable >/dev/null 2>&1 \
      && say "companion protocols updated (new features added)" \
      || warn "updating companion protocols failed — current protocols left untouched"
  fi

  # ۴) اگر پنلِ وب نصب است، کد و وابستگی‌هایش را به‌روز کن (بدون ریست رمز)
  if [ -x /usr/local/bin/kian-panel.sh ] && systemctl is-active --quiet kian-panel 2>/dev/null; then
    inf "updating the web panel..."
    bash /usr/local/bin/kian-panel.sh update >/dev/null 2>&1 \
      && say "web panel updated (new features added)" \
      || warn "panel update failed — check: systemctl status kian-panel"
  fi

  # ۴.۵) نصب‌های قدیمی را به لینکِ HTTPS روی دامنهٔ خودِ کاربر ارتقا بده
  #      (پورت پل + هندلرِ /sub/* در Caddy) — بدونِ نیاز به اقدامِ کاربر.
  ensure_domain_sub

  # ۴.۶) اگر سرور کم‌رم است و swap ندارد، فعالش کن (جلوی کرشِ سرویس‌ها).
  ensure_swap

  # ۵) همهٔ لینک‌های Subscription را بازسازی و با Gist همگام کن تا قابلیت‌های جدید
  #    (پروتکل‌های اضافه‌شده) خودکار در لینکِ همهٔ کاربران بیاید — بدونِ دادنِ لینکِ تازه.
  cmd_resync_quiet

  # ۶) ثبت نسخهٔ جدید + کاربران دست‌نخورده می‌مانند (config/users.json تغییر نکرد)
  [ -n "$sv" ] && echo "$sv" > "$ETC_DIR/script_version.txt"
  say "Update complete. Users, configs and subscription links were preserved and refreshed. (backup: $bdir/*_${bts}.*)"
  inf "To see status: kian-v2ray status"
}

# --- بازسازیِ همهٔ سابسکرایب‌ها (resync) -----------------------------------
# همهٔ لینک‌های کاربران را از روی config + کامپنیون بازمی‌سازد و با Gist همگام می‌کند.
# کاربردِ اصلی: بعد از فعال‌کردن پروتکلِ جدید یا تغییرِ متد، لینکِ همهٔ کاربران
# خودکار به‌روز می‌شود — لازم نیست کاربر لینکِ تازه به کسی بدهد.
_refresh_extra_links(){
  if [ -x /usr/local/bin/kian-protocols.sh ] && systemctl is-active --quiet kian-singbox 2>/dev/null; then
    bash /usr/local/bin/kian-protocols.sh links 2>/dev/null \
      | grep -oE '(hysteria2|tuic|anytls|ss)://[^[:space:]]+#[^[:space:]]+' \
      > "$ETC_DIR/extra_links.txt" 2>/dev/null || true
  fi
}
cmd_resync_quiet(){
  _refresh_extra_links
  cmd_sub "" >/dev/null 2>&1 || true
}
cmd_resync(){
  need_root; need_jq; need_files
  inf "rebuilding subscription links for all users..."
  _refresh_extra_links
  cmd_sub ""
  say "All subscription links rebuilt and synced with Gist — users get the new configs on refresh."
}

cmd_uninstall(){
  need_root
  warn "This only removes kian-v2ray's Xray (kian-xray) and its own files."
  warn "It does not touch other panels/Xray on this server (/etc/xray)."
  # تأییدِ غیرتعاملی برای اپ‌ها/دسکتاپ که از طریق SSH اجرا می‌کنند (بدون TTY):
  # `kian-v2ray uninstall --yes|-y|force|DELETE` یا env: KIAN_YES=1
  local confirmed=0
  case "${1:-}" in --yes|-y|force|DELETE|yes) confirmed=1 ;; esac
  [ "${KIAN_YES:-}" = "1" ] && confirmed=1
  if [ "$confirmed" != 1 ]; then
    if [ -t 0 ]; then
      read -rp "Type to confirm: DELETE  → " ans
      [ "$ans" = "DELETE" ] || { inf "Cancelled."; exit 0; }
    else
      # بدونِ TTY: اگر تأیید pipe شده باشد (echo DELETE | ...) قبولش کن، وگرنه
      # به‌جای حذفِ ناخواسته با خطا خارج شو (قبلاً اینجا بی‌صدا لغو و exit 0 می‌شد
      # و اپ‌ها فکر می‌کردند حذف شده در حالی‌که هیچ‌چیز پاک نشده بود).
      read -r ans 2>/dev/null || true
      if [ "$ans" != "DELETE" ] && [ "$ans" != "yes" ]; then
        err "Confirmation required. For non-interactive removal: kian-v2ray uninstall --yes"
        exit 2
      fi
    fi
  fi
  docker rm -f "$CONTAINER" >/dev/null 2>&1 || true
  # حذف Gistهای ابری از طریق Worker (در صورت وجود)
  if [ -f "$ETC_DIR/gist_proxy" ] && [ -f /usr/local/bin/kian-gist-sync.py ]; then
    inf "deleting cloud Gists..."
    proxy_u="$(cat "$ETC_DIR/gist_proxy" 2>/dev/null)"
    [ -n "$proxy_u" ] && python3 /usr/local/bin/kian-gist-sync.py "$proxy_u" "$ETC_DIR/install_id" "$ETC_DIR/sub" "$ETC_DIR/gist_map.json" --delete >/dev/null 2>&1 || true
  fi
  # سرویس Subscription را هم متوقف و حذف کن
  systemctl disable --now kian-sub >/dev/null 2>&1 || true
  rm -f /etc/systemd/system/kian-sub.service /usr/local/bin/kian-sub-server.py /usr/local/bin/kian-gist-sync.py
  systemctl daemon-reload >/dev/null 2>&1 || true
  # بستن پورت‌های سرویس در فایروال (اگر فعال بود)
  if command -v ufw >/dev/null 2>&1 && ufw status 2>/dev/null | grep -qi '^Status: active'; then
    for p in $(jq -r '.inbounds[]|select(((.tag//"")|startswith("reality-")) or (.tag=="shadowsocks"))|.port' "$CONFIG" 2>/dev/null); do
      ufw delete allow "${p}/tcp" >/dev/null 2>&1 || true
      ufw delete allow "${p}/udp" >/dev/null 2>&1 || true
    done
    sp="$(cat "$ETC_DIR/sub_port.txt" 2>/dev/null || echo 80)"
    for one in $(echo "$sp" | tr ',' ' '); do
      [ -n "$one" ] && ufw delete allow "${one}/tcp" >/dev/null 2>&1 || true
    done
    # پورت‌های TLS (Caddy) اگر فاز ۳ نصب شده بود
    if [ -f "$ETC_DIR/tls_domain.txt" ]; then
      ufw delete allow 80/tcp  >/dev/null 2>&1 || true
      ufw delete allow 443/tcp >/dev/null 2>&1 || true
    fi
    ufw reload >/dev/null 2>&1 || true
  fi
  # پاک‌سازی Caddyfile که ما نوشتیم (فقط اگر مال خودمان است)
  if [ -f /etc/caddy/Caddyfile ] && [ -f "$ETC_DIR/tls_domain.txt" ]; then
    local dom; dom="$(cat "$ETC_DIR/tls_domain.txt" 2>/dev/null)"
    if [ -n "$dom" ] && grep -q "^${dom} {" /etc/caddy/Caddyfile 2>/dev/null; then
      inf "stopping Caddy for this domain..."
      # اگر Caddyfile فقط بلوک ما را دارد، کاملاً پاکش می‌کنیم
      if [ "$(grep -c '^[a-z0-9.-]\+ {' /etc/caddy/Caddyfile 2>/dev/null)" = "1" ]; then
        systemctl stop caddy >/dev/null 2>&1 || true
        systemctl disable caddy >/dev/null 2>&1 || true
        rm -f /etc/caddy/Caddyfile
        warn "Caddy stopped. If this Caddy was only for kian-v2ray, you can remove it with: apt remove caddy."
      else
        # کاربر سایت دیگری هم پشت همین Caddy داشته؛ فقط بلوک خودمان را پاک می‌کنیم
        local tmpcad; tmpcad="$(mktemp)"
        awk -v d="$dom" '
          $0 ~ "^"d" {" { skip=1; brace=1; next }
          skip { for(i=1;i<=length($0);i++){c=substr($0,i,1); if(c=="{") brace++; if(c=="}") brace--}
                 if(brace<=0){skip=0; brace=0}; next }
          { print }
        ' /etc/caddy/Caddyfile > "$tmpcad" && mv "$tmpcad" /etc/caddy/Caddyfile
        systemctl reload caddy >/dev/null 2>&1 || true
        say "the $dom block was removed from the Caddyfile (Caddy keeps running for the rest)"
      fi
    fi
  fi
  rm -f /etc/cron.d/kian-v2ray-watchdog /usr/local/bin/kian-v2ray-watchdog.sh
  rm -rf "$ETC_DIR" /opt/kian-v2ray "$LOG_DIR"
  rm -f /usr/local/bin/kian-v2ray
  say "Uninstall complete. (WARP and other services were left untouched.)"
}

cmd_help(){
  sed -n '2,24p' "$0" | sed 's/^# \{0,1\}//'
}

cmd_fixperm(){
  need_root
  ensure_cfg_perm
  inf "config.json permission set to 644 (readable by the container)"
  docker restart "$CONTAINER" >/dev/null 2>&1 || docker start "$CONTAINER" >/dev/null 2>&1 || true
  sleep 3
  if docker ps --format '{{.Names}}' | grep -qx "$CONTAINER"; then
    say "Xray came up ✅ — configs should work now"
  else
    err "still not up — log: docker logs $CONTAINER --tail 20"
    docker logs "$CONTAINER" --tail 15 2>&1 || true
  fi
}

# rebind: کانتینر را با --user 0:0 و NET_BIND_SERVICE بازسازی می‌کند
# برای حل مشکل: Xray (نسخهٔ ghcr رسمی) به‌عنوان "nobody" اجرا می‌شود و نمی‌تواند
# روی پورت‌های زیر 1024 (مثل 443 و 80) bind کند.
cmd_rebind(){
  need_root
  inf "rebuilding the Xray container with permission to bind ports below 1024..."
  local img
  img="$(cat "$IMAGE_FILE" 2>/dev/null || echo 'ghcr.io/xtls/xray-core:latest')"
  docker rm -f "$CONTAINER" >/dev/null 2>&1 || true
  docker run -d --name "$CONTAINER" --restart unless-stopped --network host --memory="512m" \
    --user 0:0 --cap-add=NET_BIND_SERVICE \
    -v "$CONFIG:/etc/xray/config.json:ro" \
    -v "$LOG_DIR:/var/log/xray" \
    "$img" run -c /etc/xray/config.json >/dev/null 2>&1
  sleep 3
  if docker ps --format '{{.Names}}' | grep -qx "$CONTAINER"; then
    say "Xray came up with --user 0:0 ✅"
    # تأیید: آیا روی پورت‌های پایین واقعاً bind شد؟
    sleep 1
    inf "testing Reality ports:"
    jq -r '.inbounds[]|select((.tag//"")|startswith("reality-"))|.port' "$CONFIG" 2>/dev/null | while read p; do
      [ -z "$p" ] && continue
      if ss -tln 2>/dev/null | awk '{print $4}' | grep -qE "[:.]${p}\$"; then
        say "  ✓ port $p is listening"
      else
        err "  ✘ port $p is not bound yet"
      fi
    done
  else
    err "Xray did not come up — log: docker logs $CONTAINER --tail 30"
    docker logs "$CONTAINER" --tail 20 2>&1 || true
  fi
}

cmd_openports(){
  need_root
  if ! command -v ufw >/dev/null 2>&1; then inf "ufw not installed — ports are open"; return 0; fi
  if ! ufw status 2>/dev/null | grep -qi '^Status: active'; then
    inf "ufw firewall is not active — nothing to open (ports are reachable)"; return 0
  fi
  local ports sub; ports="$(jq -r '.inbounds[]|select(((.tag//"")|startswith("reality-")) or (.tag=="shadowsocks"))|.port' "$CONFIG" 2>/dev/null)"
  for p in $ports; do
    ufw allow "${p}/tcp" >/dev/null 2>&1 && ufw allow "${p}/udp" >/dev/null 2>&1 && say "opened: $p"
  done
  sub="$(cat "$ETC_DIR/sub_port.txt" 2>/dev/null || echo 80)"
  for one in $(echo "$sub" | tr ',' ' '); do
    # پورت پلِ ۸۷۶۵ فقط برای Caddy روی loopback است — در فایروال باز نمی‌شود.
    [ -n "$one" ] && [ "$one" != "8765" ] && ufw allow "${one}/tcp" >/dev/null 2>&1 && say "opened: $one (Subscription)"
  done
  ufw reload >/dev/null 2>&1 || true
  say "service ports opened in the firewall"
}

# --- اعمالِ امنِ کانفیگِ Xray (ویرایش از پنل): backup → اعمال → اگر Xray بالا
#     نیامد، rollback. ورودی: مسیرِ فایلِ JSONِ جدید. ----------------------------
cmd_apply_config(){
  need_root; need_jq
  local src="${1:-}"
  [ -f "$src" ] || { err "config file not found: $src"; exit 1; }
  jq -e '(.inbounds|type=="array" and length>0) and (.outbounds|type=="array" and length>0)' "$src" >/dev/null 2>&1 \
    || { err "Invalid JSON, or inbounds/outbounds are empty/missing."; exit 2; }
  local bak="$ETC_DIR/backups"; mkdir -p "$bak"
  local ts; ts="$(date -u +%Y%m%d-%H%M%S)"; local snap="$bak/config_${ts}.json"
  cp "$CONFIG" "$snap" 2>/dev/null || true
  cp "$src" "$CONFIG"; ensure_cfg_perm
  docker restart "$CONTAINER" >/dev/null 2>&1 || docker start "$CONTAINER" >/dev/null 2>&1 || true
  sleep 4
  if docker ps --format '{{.Names}}' 2>/dev/null | grep -qx "$CONTAINER"; then
    say "Config applied and Xray came up ✅ (backup: $snap)"
    return 0
  fi
  warn "Xray did not come up with the new config — rolling back"
  [ -f "$snap" ] && { cp "$snap" "$CONFIG"; ensure_cfg_perm; }
  docker restart "$CONTAINER" >/dev/null 2>&1 || docker start "$CONTAINER" >/dev/null 2>&1 || true
  err "The new config was not applied; reverted to the previous good one."
  exit 3
}

cmd_filter(){
  need_root; need_jq; need_files
  local name="${1:-}" mode="${2:-}"
  name="$(printf '%s' "$name" | tr -cd 'a-zA-Z0-9_-')"
  [ -n "$name" ] || { err "Name required:  kian-v2ray filter <name> <all|domain|nodomain>"; exit 1; }
  case "$mode" in all|domain|nodomain) : ;; *) err "Mode must be all, domain, or nodomain."; exit 1 ;; esac
  local email="${name}@kian" tmp
  jq -e --arg e "$email" '.users[]|select(.email==$e)' "$USERS_FILE" >/dev/null 2>&1 \
    || { err "No user named $name found."; exit 1; }
  tmp="$(mktemp)"
  jq --arg e "$email" --arg m "$mode" '(.users[]|select(.email==$e)).sub_filter=$m' \
    "$USERS_FILE" > "$tmp" && mv "$tmp" "$USERS_FILE" && chmod 600 "$USERS_FILE"
  say "Config type for user $name set to: $mode"
  cmd_sub "$name" >/dev/null 2>&1 || true   # rebuild only this user's subscription
  cmd_configs "$name"
}

case "${1:-help}" in
  apply-config) shift; cmd_apply_config "${1:-}" ;;
  filter)    shift; cmd_filter "$@" ;;
  status)    cmd_status ;;
  configs)   shift; cmd_configs "${1:-}" ;;
  sub)       shift; cmd_sub "${1:-}" ;;
  users)     cmd_users ;;
  add)       shift; cmd_add "$@" ;;
  remove|rm) shift; cmd_remove "$@" ;;
  reset)     shift; cmd_reset "$@" ;;
  renew)     shift; cmd_renew "$@" ;;
  update)    cmd_update ;;
  resync|sync) cmd_resync ;;
  fixport)   cmd_fixport ;;
  fixperm)   cmd_fixperm ;;
  rebind)    cmd_rebind ;;
  openports) cmd_openports ;;
  warp)      cmd_warp ;;
  protocols) # Hysteria2/TUIC/AnyTLS companion (sing-box) — additive, opt-in
    shift
    if [ -x /usr/local/bin/kian-protocols.sh ]; then
      sub="${1:-enable}"
      bash /usr/local/bin/kian-protocols.sh "$sub"
      # بعد از فعال/غیرفعال‌کردن، لینکِ همهٔ کاربران را خودکار به‌روز کن تا
      # پروتکلِ جدید بدونِ دادنِ لینکِ تازه به کاربران اضافه (یا حذف) شود.
      case "$sub" in enable|adduser|deluser|disable) cmd_resync_quiet; say "Subscription links updated (protocols synced)";; esac
    else
      err "kian-protocols.sh is not installed — reinstall or fetch from RAW"; exit 1
    fi ;;
  panel)     # deploy/manage the web panel — additive, opt-in
    shift
    if [ -x /usr/local/bin/kian-panel.sh ]; then
      bash /usr/local/bin/kian-panel.sh "${1:-enable}"
    else
      err "kian-panel.sh is not installed — reinstall or fetch from RAW"; exit 1
    fi ;;
  untune)    cmd_untune ;;
  uninstall) shift; cmd_uninstall "$@" ;;
  help|-h|--help) cmd_help ;;
  *) err "Unknown command: $1"; cmd_help; exit 1 ;;
esac
