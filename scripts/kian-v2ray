#!/usr/bin/env bash
# ============================================================================
#  kian-v2ray — ابزار مدیریت  (نصب‌شده در /usr/local/bin/kian-v2ray)
#  ریپو: https://github.com/KIAN-IRANI/kian_v2ray
#
#  دستورها:
#     kian-v2ray status              وضعیت سرویس و کاربرها
#     kian-v2ray configs [نام]       نمایش لینک کانفیگ‌ها + QR ترمینالی
#     kian-v2ray users               فهرست کاربرها + مصرف/انقضا
#     kian-v2ray add <نام> [حجم_GB] [روز]   افزودن کاربر  (پیش‌فرض 100GB / 30روز)
#     kian-v2ray remove <نام>        حذف کاربر
#     kian-v2ray reset <نام> [حجم_GB]   صفر کردن مصرف (و در صورت دادن، تنظیم حجم)
#     kian-v2ray renew <نام> [روز]   تمدید اعتبار از همین لحظه
#     kian-v2ray update              به‌روزرسانی Xray به آخرین نسخه
#     kian-v2ray fixport             رفع تداخل پورت API (کرش‌لوپ روی سرور دارای پنل دیگر)
#     kian-v2ray warp                تلاش مجدد WARP (WireGuard/MASQUE) و برگرداندن از fallback
#     kian-v2ray untune              بازگرداندن بهینه‌سازی شبکه (BBR/بافرها)
#     kian-v2ray uninstall           حذف کامل
#  «نام» می‌تواند بخشِ قبل از @ در ایمیل کاربر باشد (مثلاً user-1).
# ============================================================================
set -uo pipefail

CONTAINER="kian-xray"
WARP_PORT=40000
GIB=1073741824
ETC_DIR="/etc/kian-v2ray"
XRAY_DIR="/etc/kian-v2ray"          # config.json ایزوله (به /etc/xray دست نمی‌زند)
LOG_DIR="/var/log/kian-xray"
USERS_FILE="$ETC_DIR/users.json"
LINKS_FILE="$ETC_DIR/links.txt"
INFO_FILE="$ETC_DIR/info.txt"
IMAGE_FILE="$ETC_DIR/image.txt"
CONFIG="$XRAY_DIR/config.json"
API_FILE="$ETC_DIR/api.txt"
# پورت API ممکن است در نصب auto-fix شده باشد (مشکل ۰.۱) → از api.txt یا خود config بخوان
if [ -f "$API_FILE" ]; then API="$(cat "$API_FILE" 2>/dev/null)"; fi
[ -z "${API:-}" ] && API="127.0.0.1:$(jq -r '(.inbounds[]|select(.tag=="api")|.port)//10085' "$CONFIG" 2>/dev/null || echo 10085)"

C_G='\033[1;32m'; C_Y='\033[1;33m'; C_R='\033[1;31m'; C_B='\033[1;36m'; C_D='\033[2m'; C_N='\033[0m'
say(){ printf "${C_G}✔${C_N} %s\n" "$*"; }
inf(){ printf "${C_B}→${C_N} %s\n" "$*"; }
warn(){ printf "${C_Y}⚠${C_N} %s\n" "$*"; }
err(){ printf "${C_R}✘${C_N} %s\n" "$*" >&2; }
need_root(){ [ "$(id -u)" -eq 0 ] || { err "این دستور به root نیاز دارد (sudo)."; exit 1; }; }
need_jq(){ command -v jq >/dev/null 2>&1 || { err "jq نصب نیست."; exit 1; }; }
need_files(){ [ -f "$CONFIG" ] && [ -f "$USERS_FILE" ] || { err "نصب پیدا نشد. اول از صفحه تعاملی نصب کن."; exit 1; }; }

# --- استخراج اطلاعات سرور از config.json + links.txt ----------------------
meta_ip(){ awk -F': ' '/Server IP/{print $2; exit}' "$INFO_FILE" 2>/dev/null | tr -d ' '; }
meta_sni(){ jq -r '[.inbounds[]|select((.tag//"")|startswith("reality-"))|.streamSettings.realitySettings.serverNames[0]][0] // empty' "$CONFIG" 2>/dev/null; }
meta_sid(){ jq -r '[.inbounds[]|select((.tag//"")|startswith("reality-"))|.streamSettings.realitySettings.shortIds[0]][0] // empty' "$CONFIG" 2>/dev/null; }
meta_pbk(){ grep -oE 'pbk=[A-Za-z0-9_-]+' "$LINKS_FILE" 2>/dev/null | head -1 | cut -d= -f2; }
meta_port(){ jq -r --arg t "$1" '[.inbounds[]|select(.tag==$t)|.port][0] // empty' "$CONFIG" 2>/dev/null; }
meta_ss(){ jq -r '[.inbounds[]|select(.tag=="shadowsocks")|{p:.port,pw:(.settings.password // .settings.clients[0].password),m:(.settings.method // .settings.clients[0].method)}][0] // empty | if .==null then "" else "\(.p) \(.m) \(.pw)" end' "$CONFIG" 2>/dev/null; }

urlenc_label(){ printf '%s' "$1" | sed 's/ /%20/g'; }   # برچسب ساده‌ی ASCII

build_vless(){ # uuid port sni label
  local uuid="$1" port="$2" sni="$3" label="$4"
  printf 'vless://%s@%s:%s?encryption=none&flow=xtls-rprx-vision&security=reality&sni=%s&fp=chrome&pbk=%s&sid=%s&type=tcp#%s\n' \
    "$uuid" "$(meta_ip)" "$port" "$sni" "$(meta_pbk)" "$(meta_sid)" "$(urlenc_label "$label")"
}
show_qr(){ command -v qrencode >/dev/null 2>&1 && printf '%s' "$1" | qrencode -t ANSIUTF8 -m 1 2>/dev/null || true; }

# --- بازسازی clientها در reality inbounds از روی users.json + restart -----
rebuild_and_restart(){
  local active cfgtmp
  active="$(jq -c '[.users[]|select(.active==true)|{id:.id,email:.email,flow:"xtls-rprx-vision"}]' "$USERS_FILE")"
  cfgtmp="$(mktemp)"
  jq --argjson cl "$active" '.inbounds |= map(if ((.tag//"")|startswith("reality-")) then .settings.clients=$cl else . end)' "$CONFIG" > "$cfgtmp" 2>/dev/null
  if jq -e . "$cfgtmp" >/dev/null 2>&1; then
    mv "$cfgtmp" "$CONFIG"
    docker restart "$CONTAINER" >/dev/null 2>&1 || true
    say "کانفیگ بازسازی و Xray ری‌استارت شد"
  else
    rm -f "$cfgtmp"; err "بازسازی config ناموفق"; return 1
  fi
}

resolve_email(){ # نام یا ایمیل → ایمیل دقیق
  local q="$1"
  jq -r --arg q "$q" '[.users[]|.email|select(. == $q or (split("@")[0] == $q))][0] // empty' "$USERS_FILE"
}

# ===========================================================================
cmd_status(){
  printf "\n${C_B}━━━ kian-v2ray — وضعیت ━━━${C_N}\n\n"
  local PROBLEMS=""
  if docker ps --format '{{.Names}}' 2>/dev/null | grep -qx "$CONTAINER"; then
    say "Xray در حال اجراست  ($(cat "$IMAGE_FILE" 2>/dev/null || echo image))"
    docker ps --filter "name=$CONTAINER" --format '   آپ‌تایم: {{.Status}}'
  else
    # خودتشخیصی (۰.۳): کرش‌لوپ یا توقف؟
    local st; st="$(docker inspect -f '{{.State.Status}}' "$CONTAINER" 2>/dev/null || echo missing)"
    if [ "$st" = "restarting" ]; then
      err "Xray در کرش‌لوپ است (Restarting)"
      # علت رایج: تداخل پورت bind در لاگ
      local logtail; logtail="$(docker logs "$CONTAINER" --tail 30 2>&1 || true)"
      if printf '%s' "$logtail" | grep -qiE 'address already in use|bind:.*in use|listen.*fail'; then
        local badport; badport="$(printf '%s' "$logtail" | grep -oiE ':[0-9]+: bind|:[0-9]+ .*in use' | grep -oE '[0-9]+' | head -1)"
        err "علت: تداخل پورت${badport:+ ($badport)} — احتمالاً پنل دیگری (3x-ui/Marzban) همان پورت را گرفته"
        PROBLEMS="port"
      else
        PROBLEMS="crash"
      fi
    elif [ "$st" = "missing" ]; then
      err "کانتینر Xray وجود ندارد"
      PROBLEMS="missing"
    else
      err "Xray اجرا نمی‌شود (وضعیت: $st)"
      PROBLEMS="stopped"
    fi
  fi
  if command -v warp-cli >/dev/null 2>&1; then
    if curl -fsS --max-time 8 --socks5 "127.0.0.1:$WARP_PORT" https://1.1.1.1/cdn-cgi/trace 2>/dev/null | grep -q 'warp=on'; then
      say "WARP: متصل (socks5 :$WARP_PORT$( [ -f "$ETC_DIR/warp_proto.txt" ] && printf ' — %s' "$(cat "$ETC_DIR/warp_proto.txt")"))"
      if [ "$(cat "$ETC_DIR/warp_fallback.txt" 2>/dev/null)" = on ]; then
        warn "اما routing هنوز روی fallback (direct) است — برای برگرداندن: kian-v2ray warp"
        PROBLEMS="${PROBLEMS:+$PROBLEMS,}warpfb"
      fi
    elif [ "$(cat "$ETC_DIR/warp_fallback.txt" 2>/dev/null)" = on ]; then
      warn "WARP قطع — fallback فعال است: ترافیک warp فعلاً مستقیم می‌رود (کاربر بی‌نت نمی‌ماند)"
      PROBLEMS="${PROBLEMS:+$PROBLEMS,}warp"
    else warn "WARP: قطع — watchdog تلاش می‌کند یا: kian-v2ray warp"; PROBLEMS="${PROBLEMS:+$PROBLEMS,}warp"; fi
  else inf "WARP نصب نشده (حالت مستقیم)"; fi
  # تداخل پورت API را مستقل هم چک کن
  local apiport; apiport="${API##*:}"
  if [ -n "$apiport" ] && ss -tln 2>/dev/null | awk '{print $4}' | grep -qE "[:.]${apiport}\$"; then
    if ! docker ps --format '{{.Names}}' | grep -qx "$CONTAINER"; then
      warn "پورت API ($apiport) توسط سرویس دیگری اشغال است"
      case "$PROBLEMS" in *port*) :;; *) PROBLEMS="${PROBLEMS:+$PROBLEMS,}apiport";; esac
    fi
  fi
  if [ -f "$USERS_FILE" ]; then
    local total act
    total="$(jq '.users|length' "$USERS_FILE" 2>/dev/null)"
    act="$(jq '[.users[]|select(.active==true)]|length' "$USERS_FILE" 2>/dev/null)"
    inf "کاربرها: $act فعال از $total"
  fi
  # --- دستور رفع (۰.۳): یک خط، بدون نیاز به دانش کاربر ---
  if [ -n "$PROBLEMS" ]; then
    printf "\n${C_Y}━━━ رفع خودکار ━━━${C_N}\n"
    case "$PROBLEMS" in
      *port*|*apiport*|*missing*)
        printf "   تداخل پورت تشخیص داده شد. این دستور پورت API را به یک پورت آزاد می‌برد و Xray را بالا می‌آورد:\n"
        printf "${C_G}   kian-v2ray fixport${C_N}\n" ;;
    esac
    case "$PROBLEMS" in
      *warpfb*) printf "   WARP سالم است ولی routing روی fallback مانده. برگرداندن:  ${C_G}kian-v2ray warp${C_N}\n" ;;
    esac
    case "$PROBLEMS" in
      *warp*) printf "   WARP قطع است. تلاش مجدد (WireGuard/MASQUE + fallback):  ${C_G}kian-v2ray warp${C_N}\n" ;;
    esac
    case "$PROBLEMS" in
      *crash*) printf "   لاگ کرش:  ${C_G}docker logs $CONTAINER --tail 40${C_N}\n" ;;
    esac
    echo ""
  else
    printf "\n${C_D}برای لینک‌ها: kian-v2ray configs   |   فهرست کاربرها: kian-v2ray users${C_N}\n\n"
  fi
}

# --- مدیریت دستی WARP: تلاش مجدد (WireGuard/MASQUE) و برگرداندن از fallback ---
_warp_up(){ curl -fsS --max-time 8 --socks5 "127.0.0.1:$WARP_PORT" https://1.1.1.1/cdn-cgi/trace 2>/dev/null | grep -q 'warp=on'; }
_warp_restore_routing(){
  local FB="$ETC_DIR/warp_fallback.txt" tmp
  [ "$(cat "$FB" 2>/dev/null)" = on ] || return 0
  tmp="$(mktemp)"
  jq '(.routing.rules[]?|select((.inboundTag//[])|any(test("^reality-warp-")))|.outboundTag)="warp"' "$CONFIG" > "$tmp" \
    && jq -e . "$tmp" >/dev/null 2>&1 && mv "$tmp" "$CONFIG" || rm -f "$tmp"
  echo off > "$FB"; docker restart "$CONTAINER" >/dev/null 2>&1 || true
  say "routing به warp بازگردانده شد"
}
# --- بازگرداندن بهینه‌سازی شبکه (rollback مرحلهٔ ۰.۴) ----------------------
cmd_untune(){
  need_root
  local f="/etc/sysctl.d/99-kian-v2ray.conf"
  if [ -f "$f" ]; then rm -f "$f"; say "فایل tune حذف شد ($f)"; else inf "فایل tune وجود نداشت"; fi
  rm -f /etc/modules-load.d/bbr.conf 2>/dev/null || true
  sysctl --system >/dev/null 2>&1 || true
  inf "برای بازگشت کامل تنظیمات کرنل به مقادیر قبلی، سرور را reboot کن (یا مقادیر را از $ETC_DIR/sysctl.backup ببین)."
  say "بهینه‌سازی شبکه برگردانده شد"
}

cmd_warp(){
  need_root
  command -v warp-cli >/dev/null 2>&1 || { err "WARP نصب نیست."; exit 1; }
  inf "تلاش برای اتصال WARP..."
  warp-cli --accept-tos connect >/dev/null 2>&1 || { systemctl restart warp-svc >/dev/null 2>&1; sleep 3; warp-cli --accept-tos connect >/dev/null 2>&1; }
  sleep 5
  if ! _warp_up; then
    local cur alt; cur="$(warp-cli --accept-tos tunnel protocol get 2>/dev/null | grep -oiE 'wireguard|masque' | head -1)"
    alt="WireGuard"; echo "$cur" | grep -qi wireguard && alt="MASQUE"
    inf "تلاش با پروتکل $alt"
    warp-cli --accept-tos tunnel protocol set "$alt" >/dev/null 2>&1 || warp-cli --accept-tos set-tunnel-protocol "$alt" >/dev/null 2>&1 || true
    warp-cli --accept-tos disconnect >/dev/null 2>&1; sleep 1; warp-cli --accept-tos connect >/dev/null 2>&1 || true
    sleep 6
  fi
  if _warp_up; then say "WARP متصل است ✅"; _warp_restore_routing
  else err "WARP هنوز وصل نشد — fallback (direct) فعال می‌ماند تا کاربر بی‌نت نماند. بعداً دوباره: kian-v2ray warp"; fi
}

# --- رفع خودکار تداخل پورت API (۰.۱/۰.۳) ----------------------------------
cmd_fixport(){
  need_root; need_jq; need_files
  local cur free
  cur="$(jq -r '(.inbounds[]|select(.tag=="api")|.port)//10085' "$CONFIG")"
  if ! ss -tln 2>/dev/null | awk '{print $4}' | grep -qE "[:.]${cur}\$" || docker ps --format '{{.Names}}'|grep -qx "$CONTAINER"; then
    inf "پورت API فعلی ($cur) مشکلی ندارد — تلاش برای restart"
  fi
  free="$cur"
  local svc_ports; svc_ports="$(jq -r '[.inbounds[]|select(((.tag//"")|startswith("reality-")) or ((.tag//"")=="shadowsocks"))|.port]|join(" ")' "$CONFIG")"
  for _t in $(seq 1 300); do
    free=$(( (RANDOM % 30000) + 20000 ))
    ss -tln 2>/dev/null | awk '{print $4}' | grep -qE "[:.]${free}\$" && continue
    printf '%s\n' $svc_ports | grep -qx "$free" && continue
    break
  done
  local tmpc; tmpc="$(mktemp)"
  jq --argjson new "$free" '(.inbounds[]|select(.tag=="api")|.port)|=$new' "$CONFIG" > "$tmpc" && mv "$tmpc" "$CONFIG"
  jq -e . "$CONFIG" >/dev/null || { err "config خراب شد — بازگردانی لازم است"; exit 1; }
  echo "127.0.0.1:${free}" > "$API_FILE"
  docker restart "$CONTAINER" >/dev/null 2>&1 || docker start "$CONTAINER" >/dev/null 2>&1 || true
  sleep 3
  if docker ps --format '{{.Names}}'|grep -qx "$CONTAINER"; then say "پورت API به $free تغییر کرد و Xray بالا آمد ✅"
  else err "هنوز بالا نیامد — لاگ: docker logs $CONTAINER --tail 40"; fi
}

cmd_users(){
  need_jq; need_files
  printf "\n${C_B}%-22s %-9s %-12s %-12s %s${C_N}\n" "ایمیل" "فعال" "مصرف" "حجم" "انقضا"
  printf '%.0s─' {1..72}; printf '\n'
  jq -r '.users[] | [
      .email, (if .active then "بله" else "خیر" end),
      ((.used_bytes/1073741824*100|floor)/100|tostring)+"G",
      (if .quota_bytes>0 then ((.quota_bytes/1073741824)|tostring)+"G" else "∞" end),
      (.expires_at // "دائمی")
    ] | @tsv' "$USERS_FILE" | while IFS=$'\t' read -r e a u q x; do
      printf "%-22s %-9s %-12s %-12s %s\n" "$e" "$a" "$u" "$q" "$x"
    done
  echo ""
}

cmd_configs(){
  need_jq; need_files
  local filter="${1:-}" ss inbounds_tsv
  ss="$(meta_ss)"
  [ -n "$(meta_pbk)" ] || { err "کلید عمومی در links.txt پیدا نشد."; exit 1; }

  # همهٔ inboundهای reality:  tag \t port \t sni
  inbounds_tsv="$(jq -r '.inbounds[]|select((.tag//"")|startswith("reality-"))|[.tag,(.port|tostring),(.streamSettings.realitySettings.serverNames[0]//"")]|@tsv' "$CONFIG")"

  jq -r '.users[]|select(.active==true)|.id+"\t"+.email' "$USERS_FILE" | while IFS=$'\t' read -r uuid email; do
    local local_name="${email%@*}"
    [ -n "$filter" ] && [ "$filter" != "$local_name" ] && [ "$filter" != "$email" ] && continue
    printf "\n${C_B}👤 %s${C_N}\n" "$local_name"
    printf '%s\n' "$inbounds_tsv" | while IFS=$'\t' read -r tag port sni; do
      [ -z "$tag" ] && continue
      local ch="سریع"; case "$tag" in *warp*) ch="WARP";; esac
      local l; l="$(build_vless "$uuid" "$port" "$sni" "KIAN-${local_name}-${ch}-${sni}")"
      printf "${C_G}• %s · %s · پورت %s:${C_N}\n%s\n" "$ch" "$sni" "$port" "$l"; show_qr "$l"
    done
  done
  if [ -n "$ss" ] && { [ -z "$filter" ] || [ "$filter" = "ss" ]; }; then
    read -r sp sm spw <<<"$ss"
    local l; l="ss://$(printf '%s' "$sm:$spw" | base64 -w0)@$(meta_ip):$sp#KIAN-SS"
    printf "\n${C_B}🧩 Shadowsocks (مشترک):${C_N}\n%s\n" "$l"; show_qr "$l"
  fi
  echo ""
}

cmd_add(){
  need_root; need_jq; need_files
  local name="${1:-}" gb="${2:-100}" days="${3:-30}"
  [ -n "$name" ] || { err "نام لازم است:  kian-v2ray add <نام> [حجم_GB] [روز]"; exit 1; }
  name="$(printf '%s' "$name" | tr -cd 'a-zA-Z0-9_-')"
  local email="${name}@kian"
  if jq -e --arg e "$email" '.users[]|select(.email==$e)' "$USERS_FILE" >/dev/null 2>&1; then
    err "کاربری با ایمیل $email از قبل وجود دارد."; exit 1
  fi
  local uuid quota exp tmp
  uuid="$(cat /proc/sys/kernel/random/uuid)"
  quota=$(( gb * GIB )); [ "$gb" -le 0 ] && quota=0
  if [ "$days" -gt 0 ]; then exp="\"$(date -u -d "+${days} days" +%FT%TZ)\""; else exp="null"; fi
  tmp="$(mktemp)"
  jq --arg id "$uuid" --arg e "$email" --argjson q "$quota" --argjson x "$exp" \
    '.users += [{id:$id,email:$e,quota_bytes:$q,used_bytes:0,expires_at:$x,active:true,note:""}]' \
    "$USERS_FILE" > "$tmp" && mv "$tmp" "$USERS_FILE" && chmod 600 "$USERS_FILE"
  rebuild_and_restart
  say "کاربر افزوده شد: $email  (حجم: $([ "$gb" -le 0 ] && echo ∞ || echo ${gb}G) / مدت: $([ "$days" -le 0 ] && echo دائمی || echo ${days}روز))"
  cmd_configs "$name"
}

cmd_remove(){
  need_root; need_jq; need_files
  local q="${1:-}"; [ -n "$q" ] || { err "نام لازم است:  kian-v2ray remove <نام>"; exit 1; }
  local email; email="$(resolve_email "$q")"
  [ -n "$email" ] || { err "کاربری با نام/ایمیل «$q» پیدا نشد."; exit 1; }
  local tmp; tmp="$(mktemp)"
  jq --arg e "$email" '.users |= map(select(.email != $e))' "$USERS_FILE" > "$tmp" && mv "$tmp" "$USERS_FILE" && chmod 600 "$USERS_FILE"
  rebuild_and_restart
  say "کاربر حذف شد: $email"
}

cmd_reset(){
  need_root; need_jq; need_files
  local q="${1:-}" gb="${2:-}"; [ -n "$q" ] || { err "نام لازم است."; exit 1; }
  local email; email="$(resolve_email "$q")"; [ -n "$email" ] || { err "کاربر پیدا نشد."; exit 1; }
  local tmp; tmp="$(mktemp)"
  if [ -n "$gb" ]; then
    local quota=$(( gb * GIB )); [ "$gb" -le 0 ] && quota=0
    jq --arg e "$email" --argjson q "$quota" '.users |= map(if .email==$e then (.used_bytes=0|.active=true|.quota_bytes=$q) else . end)' "$USERS_FILE" > "$tmp"
  else
    jq --arg e "$email" '.users |= map(if .email==$e then (.used_bytes=0|.active=true) else . end)' "$USERS_FILE" > "$tmp"
  fi
  mv "$tmp" "$USERS_FILE" && chmod 600 "$USERS_FILE"
  rebuild_and_restart
  say "مصرف صفر شد: $email${gb:+  (حجم جدید: ${gb}G)}"
}

cmd_renew(){
  need_root; need_jq; need_files
  local q="${1:-}" days="${2:-30}"; [ -n "$q" ] || { err "نام لازم است."; exit 1; }
  local email; email="$(resolve_email "$q")"; [ -n "$email" ] || { err "کاربر پیدا نشد."; exit 1; }
  local exp tmp
  if [ "$days" -gt 0 ]; then exp="\"$(date -u -d "+${days} days" +%FT%TZ)\""; else exp="null"; fi
  tmp="$(mktemp)"
  jq --arg e "$email" --argjson x "$exp" '.users |= map(if .email==$e then (.expires_at=$x|.active=true) else . end)' "$USERS_FILE" > "$tmp"
  mv "$tmp" "$USERS_FILE" && chmod 600 "$USERS_FILE"
  rebuild_and_restart
  say "تمدید شد: $email  (تا $([ "$days" -le 0 ] && echo دائمی || echo "${days} روز دیگر"))"
}

cmd_update(){
  need_root
  inf "گرفتن آخرین نسخه‌ی Xray-core..."
  local tag img
  tag="$(curl -fsSL https://api.github.com/repos/XTLS/Xray-core/releases/latest 2>/dev/null | jq -r '.tag_name // empty' | sed 's/^v//')"
  if [ -n "$tag" ]; then img="ghcr.io/xtls/xray-core:$tag"; else img="ghcr.io/xtls/xray-core:latest"; fi
  if docker pull "$img" >/dev/null 2>&1; then
    echo "$img" > "$IMAGE_FILE"
    docker rm -f "$CONTAINER" >/dev/null 2>&1 || true
    docker run -d --name "$CONTAINER" --restart unless-stopped --network host --memory="512m" \
      -v "$CONFIG:/etc/xray/config.json:ro" -v "$LOG_DIR:/var/log/xray" \
      "$img" run -c /etc/xray/config.json >/dev/null
    sleep 2
    docker ps --format '{{.Names}}' | grep -qx "$CONTAINER" && say "به‌روزرسانی شد → $img" || err "کانتینر بالا نیامد"
  else err "pull نسخه ناموفق ($img)"; fi
}

cmd_uninstall(){
  need_root
  warn "این کار فقط Xrayِ kian-v2ray (kian-xray) و فایل‌های خودش را حذف می‌کند."
  warn "به پنل‌ها/Xrayهای دیگرِ این سرور (/etc/xray) دست نمی‌زند."
  read -rp "برای تأیید بنویس: DELETE  → " ans
  [ "$ans" = "DELETE" ] || { inf "لغو شد."; exit 0; }
  docker rm -f "$CONTAINER" >/dev/null 2>&1 || true
  rm -f /etc/cron.d/kian-v2ray-watchdog /usr/local/bin/kian-v2ray-watchdog.sh
  rm -rf "$ETC_DIR" /opt/kian-v2ray "$LOG_DIR"
  rm -f /usr/local/bin/kian-v2ray
  say "حذف کامل شد. (WARP و سایر سرویس‌ها دست‌نخورده ماندند.)"
}

cmd_help(){
  sed -n '2,24p' "$0" | sed 's/^# \{0,1\}//'
}

case "${1:-help}" in
  status)    cmd_status ;;
  configs)   shift; cmd_configs "${1:-}" ;;
  users)     cmd_users ;;
  add)       shift; cmd_add "$@" ;;
  remove|rm) shift; cmd_remove "$@" ;;
  reset)     shift; cmd_reset "$@" ;;
  renew)     shift; cmd_renew "$@" ;;
  update)    cmd_update ;;
  fixport)   cmd_fixport ;;
  warp)      cmd_warp ;;
  untune)    cmd_untune ;;
  uninstall) cmd_uninstall ;;
  help|-h|--help) cmd_help ;;
  *) err "دستور ناشناخته: $1"; cmd_help; exit 1 ;;
esac
